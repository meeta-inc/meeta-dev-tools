# SAM 배포 시 파라미터로 입력하므로 .env 파일은 불필요합니다.
# 로컬 테스트용으로만 사용하세요.

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# GitHub Actions
GITHUB_TOKEN=ghp_your-github-token
GITHUB_OWNER=your-org
GITHUB_REPO=ai-bridge-infra
GITHUB_WORKFLOW_FILE=scheduled-env-control.yml
GITHUB_REF=main

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SSM
SSM_PARAMETER_PREFIX=/ai-bridge/dev/env-control

# 감사 로그를 전송할 Slack 채널 ID
ALERT_CHANNEL_ID=C0000000000

# /dev 커맨드를 허용할 채널 ID (쉼표 구분, 비우면 모든 채널 허용)
ALLOWED_CHANNEL_IDS=
